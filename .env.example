# App Settings
APP_NAME=闲鱼AI助手
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ticket_bot
REDIS_URL=redis://localhost:6379/0

# Claude API
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=1024

# Lark (Feishu)
LARK_APP_ID=your_lark_app_id
LARK_APP_SECRET=your_lark_app_secret
LARK_BOT_NAME=闲鱼AI助手

# Xianyu
XIANYU_PHONE=your_xianyu_phone
XIANYU_PASSWORD=your_xianyu_password

# Service Fee
SERVICE_FEE_RATE=0.05
MIN_SERVICE_FEE=2.0
